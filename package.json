{
  "packageManager": "npm@11.14.1",
  "engines": {
    "node": ">=24.0.0",
    "npm": ">=11.14.1"
  },
  "scripts": {
    "build": "npm run og && npm run build:site && npm run seo",
    "build:site": "eleventy",
    "og": "node scripts/generate-og-images.mjs",
    "seo": "node scripts/generate-seo.mjs _site",
    "dev": "npm run og && eleventy --serve"
  },
  "devDependencies": {
    "@11ty/eleventy": "3.1.2",
    "@resvg/resvg-js": "2.6.2"
  }
}
