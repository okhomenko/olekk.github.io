<!doctype html>
<html lang="en">
  <head>
    {% set pageTitle = title or site.title %}
    {% if pageTitle == site.title %}
      {% set fullTitle = site.title %}
    {% else %}
      {% set fullTitle = pageTitle + ' | ' + site.title %}
    {% endif %}
    {% set pageDescription = description or site.description %}
    {% set canonicalUrl = page.url | absoluteUrl(site.url) %}
    {% set ogImage = (ogImage or site.defaultOgImage) | absoluteUrl(site.url) %}
    {% set ogImageAlt = ogImageAlt or site.defaultOgImageAlt %}
    {% set ogImageWidth = ogImageWidth or site.defaultOgImageWidth %}
    {% set ogImageHeight = ogImageHeight or site.defaultOgImageHeight %}
    {% set ogImageType = ogImageType or site.defaultOgImageType %}
    {% set pageStructuredData = structuredData %}
    {% if not pageStructuredData and page.url == "/" %}
      {% set pageStructuredData = [
        {
          '@context': 'https://schema.org',
          '@type': 'Person',
          name: site.author,
          url: site.url,
          sameAs: site.socialProfiles,
          knowsAbout: [
            'Software engineering',
            'AI-enabled software development',
            'Product architecture',
            'Systems thinking',
            'Technical leadership',
            'Endurance running'
          ]
        },
        {
          '@context': 'https://schema.org',
          '@type': 'WebSite',
          name: site.title,
          url: site.url,
          description: pageDescription
        }
      ] %}
    {% endif %}
    {% if not pageStructuredData and date %}
      {% set pageStructuredData = {
        '@context': 'https://schema.org',
        '@type': 'BlogPosting',
        headline: title,
        description: pageDescription,
        author: {
          '@type': 'Person',
          name: site.author,
          url: site.url
        },
        datePublished: date | htmlDateString,
        dateModified: (updated or date) | htmlDateString,
        mainEntityOfPage: {
          '@type': 'WebPage',
          '@id': canonicalUrl
        }
      } %}
    {% endif %}

    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="color-scheme" content="light dark" />
    <meta name="theme-color" content="#f8f6f1" />
    <script>
      (function () {
        var storageKey = 'theme';
        var colors = { light: '#f8f6f1', dark: '#151515' };
        var storedTheme;

        try {
          storedTheme = localStorage.getItem(storageKey);
        } catch (error) {
          storedTheme = null;
        }

        var preferredTheme = window.matchMedia('(prefers-color-scheme: dark)').matches ? 'dark' : 'light';
        var theme = storedTheme === 'light' || storedTheme === 'dark' ? storedTheme : preferredTheme;
        var themeColor = document.querySelector('meta[name="theme-color"]');

        document.documentElement.dataset.theme = theme;
        document.documentElement.style.colorScheme = theme;

        if (themeColor) {
          themeColor.setAttribute('content', colors[theme]);
        }
      })();
    </script>

    <title>{{ fullTitle }}</title>

    <link rel="icon" type="image/svg+xml" sizes="any" href="/favicon.svg" data-theme-icon />
    <link rel="icon" type="image/svg+xml" sizes="any" href="/favicon-light.svg" media="(prefers-color-scheme: light)" />
    <link rel="icon" type="image/svg+xml" sizes="any" href="/favicon-dark.svg" media="(prefers-color-scheme: dark)" />

    <meta name="description" content="{{ pageDescription }}" />
    <link rel="canonical" href="{{ canonicalUrl }}" />

    <meta name="robots" content="index,follow" />

    <meta property="og:type" content="{{ ogType or ('article' if date else 'website') }}" />
    <meta property="og:title" content="{{ fullTitle }}" />
    <meta property="og:description" content="{{ pageDescription }}" />
    <meta property="og:url" content="{{ canonicalUrl }}" />
    <meta property="og:image" content="{{ ogImage }}" />
    {% if ogImageType %}<meta property="og:image:type" content="{{ ogImageType }}" />{% endif %}
    {% if ogImageWidth %}<meta property="og:image:width" content="{{ ogImageWidth }}" />{% endif %}
    {% if ogImageHeight %}<meta property="og:image:height" content="{{ ogImageHeight }}" />{% endif %}
    {% if ogImageAlt %}<meta property="og:image:alt" content="{{ ogImageAlt }}" />{% endif %}
    <meta property="og:site_name" content="{{ site.title }}" />
    {% if date %}
    <meta property="article:published_time" content="{{ date | htmlDateString }}" />
    <meta property="article:modified_time" content="{{ (updated or date) | htmlDateString }}" />
    {% endif %}

    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content="{{ fullTitle }}" />
    <meta name="twitter:description" content="{{ pageDescription }}" />
    <meta name="twitter:image" content="{{ ogImage }}" />
    {% if ogImageAlt %}<meta name="twitter:image:alt" content="{{ ogImageAlt }}" />{% endif %}

    <link rel="alternate" type="application/atom+xml" title="{{ site.title }} Feed" href="{{ '/feed.xml' | absoluteUrl(site.url) }}" />

    {% if pageStructuredData %}
    <script type="application/ld+json">
{{ pageStructuredData | json | safe }}
    </script>
    {% endif %}

    <link rel="stylesheet" href="/style.css?v=20260518-identity" />
    <script src="/theme.js?v=20260513-theme-toggle" defer></script>
  </head>
  <body>
    <header>
      <p class="site-title">
        <a href="/">Oleksandr Khomenko <span class="site-title-flag" role="img" aria-label="Ukrainian flag">🇺🇦</span></a>
      </p>
      <div class="identity-links header-identity" aria-label="Profiles">
        <a rel="me" href="{{ site.social.github.url }}" aria-label="{{ site.social.github.label }} profile for {{ site.social.github.handle }}">
          <svg aria-hidden="true" focusable="false" viewBox="0 0 24 24">
            <path d="M7.2 9.1 6.4 5.7l3.2 1.2a8.3 8.3 0 0 1 4.8 0l3.2-1.2-.8 3.4a6 6 0 0 1 1.1 3.5c0 3.2-2.6 5.8-5.9 5.8s-5.9-2.6-5.9-5.8c0-1.3.4-2.5 1.1-3.5Z" />
            <path d="M9.4 18.2v-1.6c0-.7.5-1.2 1.2-1.2h2.8c.7 0 1.2.5 1.2 1.2v1.6" />
          </svg>
          <span>{{ site.social.github.handle }}</span>
        </a>
        <a rel="me" href="{{ site.social.twitter.url }}" aria-label="{{ site.social.twitter.label }} profile for {{ site.social.twitter.handle }}">
          <svg aria-hidden="true" focusable="false" viewBox="0 0 24 24">
            <path d="M5 5l14 14" />
            <path d="M19 5 5 19" />
          </svg>
          <span>{{ site.social.twitter.handle }}</span>
        </a>
      </div>
      <p class="tagline">Engineering systems, AI-assisted development, and software organizations under real constraints.</p>
      <nav aria-label="Primary">
        <a href="/">Home</a>
        <a href="/engineering.html">Engineering</a>
        <a href="/running.html">Running</a>
        <a href="/life.html">Life</a>
        <a href="/about.html">About</a>
        <a href="/links.html">Links</a>
        <button class="theme-toggle" type="button" aria-label="Enable dark mode" aria-pressed="false" data-theme-toggle>
          <span class="theme-toggle-track" aria-hidden="true">
            <span class="theme-toggle-thumb"></span>
          </span>
          <span class="theme-toggle-label">Dark</span>
        </button>
      </nav>
    </header>

    <main>
      {{ content | safe }}
    </main>

    <footer>
      <span>Plain HTML. Durable links. Generated with Eleventy.</span>
      <span class="footer-links" aria-label="Profiles">
        <a rel="me" href="{{ site.social.github.url }}">GitHub</a>
        <a rel="me" href="{{ site.social.twitter.url }}">Twitter/X</a>
        <a rel="me" href="{{ site.social.linkedin.url }}">LinkedIn</a>
      </span>
    </footer>

    {% if site.analytics.cloudflareBeaconToken %}
    <!-- Cloudflare Web Analytics -->
    <script defer src="https://static.cloudflareinsights.com/beacon.min.js" data-cf-beacon='{"token":"{{ site.analytics.cloudflareBeaconToken }}"}'></script>
    <!-- End Cloudflare Web Analytics -->
    {% endif %}
  </body>
</html>
