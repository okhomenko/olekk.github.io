---
layout: layouts/base.njk
---

<h1>{{ title }}</h1>

{{ content | safe }}

{% if categoryPostsHeading %}
<h2>{{ categoryPostsHeading }}</h2>
{% endif %}

<ul class="posts">
  {% for post in collections.posts | withAnyTag(categoryTags) | reverse %}
    <li>
      <a href="{{ post.url }}">{{ post.data.title }}</a>
      <time datetime="{{ post.date | htmlDateString }}">
        {{ post.date | readableDate }}
      </time>
      <p class="description">{{ post.data.description }}</p>
    </li>
  {% endfor %}
</ul>
